{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/db" },
    { "path": "packages/agentledger-emitter" },
    { "path": "packages/agentledger-store" }
  ],
  "include": [],
  "exclude": ["node_modules"]
}
